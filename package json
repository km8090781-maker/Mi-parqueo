import React, { useState, useEffect, useMemo, useRef } from 'react';
import { initializeApp } from 'firebase/app';
import { getFirestore, collection, doc, setDoc, onSnapshot, query, deleteDoc } from 'firebase/firestore';
import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from 'firebase/auth';
import { 
  Car, Clock, Plus, Search, History, Settings, LayoutDashboard, Bike, Truck,
  Trash2, DollarSign, QrCode, X, Printer, Camera, Download, Calendar, BarChart3,
  Droplets, Check, ScanText, RotateCcw, Fingerprint, Users, UserPlus, Lock, ArrowRight,
  Sun, Moon, PlusCircle, Timer, CreditCard, RefreshCw, AlertCircle
} from 'lucide-react';

// --- CONFIGURACIÓN DE FIREBASE ---
let app, auth, db, appId;
try {
  const firebaseConfig = JSON.parse(typeof __firebase_config !== 'undefined' ? __firebase_config : '{}');
  app = initializeApp(firebaseConfig);
  auth = getAuth(app);
  db = getFirestore(app);
  appId = typeof __app_id !== 'undefined' ? __app_id : 'parking-pro-bolivia';
} catch (e) {
  console.error("Error inicializando Firebase:", e);
}

const App = () => {
  // --- ESTADOS DE AUTENTICACIÓN ---
  const [user, setUser] = useState(null);
  const [isLocked, setIsLocked] = useState(true);
  const [authLoading, setAuthLoading] = useState(false);
  const [syncing, setSyncing] = useState(false);
  const [employees, setEmployees] = useState([
    { id: 'admin', name: 'Administrador', role: 'admin' }, 
    { id: 'op1', name: 'Juan Pérez', role: 'operador' }
  ]);

  // --- ESTADOS DE LA APLICACIÓN ---
  const [view, setView] = useState('dashboard');
  const [activeVehicles, setActiveVehicles] = useState([]);
  const [historyRecords, setHistoryRecords] = useState([]);
  const [searchQuery, setSearchQuery] = useState('');
  
  // Modales
  const [showTicket, setShowTicket] = useState(null);
  const [checkoutVehicle, setCheckoutVehicle] = useState(null);
  const [isScanningQR, setIsScanningQR] = useState(false);
  const [isScanningPlate, setIsScanningPlate] = useState(false);
  const [showBathConfirm, setShowBathConfirm] = useState(false);
  const [ocrLoading, setOcrLoading] = useState(false);

  // Configuraciones del parqueo
  const [capacity, setCapacity] = useState(30);
  const [bathPrice, setBathPrice] = useState(2.00);
  
  // Modalidades por defecto (Incluyendo los turnos solicitados)
  const [modalities, setModalities] = useState([
    { id: 'm1', name: 'Tarifa por Hora', price: 10, type: 'hour', vehicle: 'car' },
    { id: 'm2', name: 'Turno Mañana (7am - 1pm)', price: 15, type: 'block', startTime: '07:00', endTime: '13:00', overagePrice: 1, vehicle: 'car' },
    { id: 'm3', name: 'Turno Tarde (1pm - 7pm)', price: 15, type: 'block', startTime: '13:00', endTime: '19:00', overagePrice: 1, vehicle: 'car' },
    { id: 'm4', name: 'Día Completo', price: 50, type: 'fixed', vehicle: 'car' },
    { id: 'm5', name: 'Tarifa Hora Moto', price: 5, type: 'hour', vehicle: 'moto' }
  ]);

  const [formData, setFormData] = useState({ plate: '', type: 'car' });
  const videoRef = useRef(null);

  // --- EFECTOS DE INICIO Y SINCRONIZACIÓN ---
  useEffect(() => {
    if (!auth) return;
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (error) { console.error("Error de autenticación:", error); }
    };
    initAuth();
    const unsubscribe = onAuthStateChanged(auth, setUser);
    return () => unsubscribe();
  }, []);

  useEffect(() => {
    if (!user || !db) return;
    setSyncing(true);

    const unsubVehicles = onSnapshot(query(collection(db, 'artifacts', appId, 'public', 'data', 'activeVehicles')), (snap) => {
      setActiveVehicles(snap.docs.map(d => ({ id: d.id, ...d.data() })).sort((a,b) => b.entryTime - a.entryTime));
      setSyncing(false);
    }, console.error);

    const unsubHistory = onSnapshot(query(collection(db, 'artifacts', appId, 'public', 'data', 'history')), (snap) => {
      setHistoryRecords(snap.docs.map(d => ({ id: d.id, ...d.data() })).sort((a,b) => b.exitTime - a.exitTime));
    }, console.error);

    const unsubModalities = onSnapshot(query(collection(db, 'artifacts', appId, 'public', 'data', 'modalities')), (snap) => {
      if (!snap.empty) setModalities(snap.docs.map(d => ({ id: d.id, ...d.data() })));
    }, console.error);

    return () => { unsubVehicles(); unsubHistory(); unsubModalities(); };
  }, [user]);

  // --- ESTADÍSTICAS ---
  const stats = useMemo(() => {
    const today = new Date().setHours(0,0,0,0);
    const dayRecs = historyRecords.filter(h => h.exitTime >= today);
    return { day: { total: dayRecs.reduce((sum, r) => sum + parseFloat(r.totalCost), 0), count: dayRecs.length } };
  }, [historyRecords]);

  // --- MOTOR DE CÁLCULO DE TARIFAS ---
  const calculateModalityCost = (entryTimeMs, exitTimeMs, mod) => {
    const diffHours = Math.ceil((exitTimeMs - entryTimeMs) / (1000 * 60 * 60)) || 1;
    
    if (mod.type === 'hour') return (diffHours * parseFloat(mod.price)).toFixed(2);
    if (mod.type === 'fixed') return parseFloat(mod.price).toFixed(2);
    
    // Lógica para "Turno + Extra" (Bloque Horario)
    if (mod.type === 'block') {
      const entryDate = new Date(entryTimeMs);
      const [endH, endM] = (mod.endTime || '13:00').split(':').map(Number);
      const blockEnd = new Date(entryTimeMs);
      blockEnd.setHours(endH, endM, 0, 0);
      
      // Si la hora de fin es menor a la hora de entrada, asumimos que el turno termina al día siguiente
      if (blockEnd < entryDate) {
        blockEnd.setDate(blockEnd.getDate() + 1);
      }
      
      let total = parseFloat(mod.price);
      if (exitTimeMs > blockEnd.getTime()) {
        const extraMs = exitTimeMs - blockEnd.getTime();
        const extraHours = Math.ceil(extraMs / (1000 * 60 * 60));
        total += extraHours * parseFloat(mod.overagePrice || 0);
      }
      return total.toFixed(2);
    }
    return "0.00";
  };

  const getSuggestedCost = (vehicle) => {
    // Busca la primera tarifa por hora para mostrar un sugerido rápido en el dashboard
    const baseMod = modalities.find(m => m.vehicle === vehicle.type && m.type === 'hour') || { price: 10, type: 'hour' };
    return calculateModalityCost(vehicle.entryTime, Date.now(), baseMod);
  };

  // --- LÓGICA DE NEGOCIO ---
  const handleLogin = (emp) => { setUser({ ...user, displayName: emp.name, role: emp.role }); setIsLocked(false); };
  
  const handleBiometricAuth = () => {
    setAuthLoading(true);
    setTimeout(() => {
      setUser({ ...user, displayName: employees[0].name, role: employees[0].role });
      setIsLocked(false);
      setAuthLoading(false);
    }, 1500);
  };

  const saveModality = async (mod) => {
    if (!db) return;
    const modId = mod.id || `MOD-${Date.now()}`;
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'modalities', modId), { ...mod, id: modId });
  };

  const deleteModality = async (id) => {
    if (!db) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'modalities', id));
  };

  const handleCheckIn = async (e) => {
    e.preventDefault();
    if (!formData.plate || activeVehicles.length >= capacity || !db) return;

    const id = `PK-${Math.random().toString(36).substr(2, 5).toUpperCase()}`;
    const newEntry = {
      id, plate: formData.plate.toUpperCase(), type: formData.type, entryTime: Date.now(), registeredBy: user?.displayName || 'Sistema'
    };

    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'activeVehicles', id), newEntry);
    setShowTicket(newEntry);
    setFormData({ plate: '', type: 'car' });
    setView('dashboard');
  };

  const handleCheckOut = async (vehicle, mod, precalculatedCost) => {
    if (!db) return;
    const record = {
      ...vehicle,
      exitTime: Date.now(),
      totalCost: precalculatedCost,
      rateApplied: mod.name,
      processedBy: user?.displayName || 'Sistema'
    };

    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'history', vehicle.id), record);
    await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'activeVehicles', vehicle.id));
    setCheckoutVehicle(null);
    setSearchQuery('');
  };

  const confirmBathService = async () => {
    if (!db) return;
    const id = `BT-${Date.now().toString().slice(-6)}`;
    const record = {
      id, plate: "SERVICIO BAÑO", type: "baño", entryTime: Date.now(), exitTime: Date.now(),
      totalCost: bathPrice.toFixed(2), rateApplied: "Único", processedBy: user?.displayName || 'Sistema'
    };
    await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'history', id), record);
    setShowBathConfirm(false);
  };

  const exportToCSV = (periodLabel, records) => {
    if (records.length === 0) return;
    const headers = ["ID", "Placa/Servicio", "Tipo", "Hora Ingreso", "Hora Salida", "Monto (Bs.)", "Modalidad", "Operador"];
    const rows = records.map(r => [
      r.id, r.plate, r.type, new Date(r.entryTime).toLocaleString('es-BO'), new Date(r.exitTime).toLocaleString('es-BO'), 
      r.totalCost, r.rateApplied, r.processedBy || r.registeredBy
    ]);
    const csvContent = [headers, ...rows].map(e => e.join(",")).join("\n");
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement("a");
    link.href = URL.createObjectURL(blob);
    link.download = `Reporte_Parqueo_${periodLabel}_${new Date().toISOString().split('T')[0]}.csv`;
    link.click();
  };

  // --- CÁMARA / OCR / QR ---
  const startCamera = async (isOCR) => {
    isOCR ? setIsScanningPlate(true) : setIsScanningQR(true);
    try {
      const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
      if (videoRef.current) videoRef.current.srcObject = stream;
    } catch (err) { alert("Cámara no disponible"); isOCR ? setIsScanningPlate(false) : setIsScanningQR(false); }
  };

  const stopCamera = () => {
    if (videoRef.current?.srcObject) videoRef.current.srcObject.getTracks().forEach(t => t.stop());
    setIsScanningPlate(false); setIsScanningQR(false);
  };

  const simulateOCR = () => {
    setOcrLoading(true);
    setTimeout(() => {
      const mockPlates = ["4821-HJL", "3312-BNM", "1020-PTR"];
      setFormData({ ...formData, plate: mockPlates[Math.floor(Math.random() * mockPlates.length)] });
      setOcrLoading(false); stopCamera();
    }, 1500);
  };

  // --- COMPONENTES UI AUXILIARES ---
  const filteredVehicles = activeVehicles.filter(v => v.plate.includes(searchQuery.toUpperCase()) || v.id.includes(searchQuery.toUpperCase()));

  const ModalityEditor = () => {
    const [newMod, setNewMod] = useState({ name: '', price: 15, type: 'hour', vehicle: 'car', startTime: '07:00', endTime: '13:00', overagePrice: 1 });
    return (
      <div className="space-y-6">
        <div className="bg-white rounded-[2rem] p-6 border border-slate-100 shadow-sm">
          <h3 className="font-black text-slate-800 mb-4 flex items-center gap-2"><PlusCircle size={18} className="text-blue-600" /> Crear Regla de Cobro</h3>
          <div className="grid grid-cols-2 gap-3 mb-4">
            <input placeholder="Nombre (ej. Turno Mañana)" className="col-span-2 p-4 bg-slate-50 rounded-2xl outline-none text-sm font-bold border border-slate-200 focus:border-blue-500" value={newMod.name} onChange={e => setNewMod({...newMod, name: e.target.value})} />
            
            <div className="relative">
              <span className="absolute left-4 top-1/2 -translate-y-1/2 text-[10px] font-black text-slate-400 uppercase">Tarifa Bs.</span>
              <input type="number" className="w-full p-4 pl-16 bg-slate-50 rounded-2xl outline-none text-sm font-black border border-slate-200 text-blue-600 focus:border-blue-500" value={newMod.price} onChange={e => setNewMod({...newMod, price: e.target.value})} />
            </div>
            
            <select className="p-4 bg-slate-50 rounded-2xl outline-none text-xs font-bold border border-slate-200" value={newMod.type} onChange={e => setNewMod({...newMod, type: e.target.value})}>
              <option value="hour">Por Hora</option>
              <option value="block">Turno + Extra</option>
              <option value="fixed">Precio Fijo</option>
            </select>
            
            <select className="p-4 bg-slate-50 rounded-2xl outline-none text-xs font-bold border border-slate-200 col-span-2" value={newMod.vehicle} onChange={e => setNewMod({...newMod, vehicle: e.target.value})}>
              <option value="car">Aplica a: Automóvil</option><option value="moto">Aplica a: Motocicleta</option><option value="truck">Aplica a: Carga Pesada</option>
            </select>

            {/* Ajustes específicos para "Turno + Extra" */}
            {newMod.type === 'block' && (
              <div className="col-span-2 grid grid-cols-3 gap-2 mt-2 p-4 bg-blue-50/50 rounded-2xl border border-blue-100">
                <div>
                  <label className="text-[9px] font-black text-blue-800 uppercase tracking-widest block mb-1">Inicia</label>
                  <input type="time" className="w-full p-3 rounded-xl text-xs font-bold border border-blue-200 outline-none" value={newMod.startTime} onChange={e => setNewMod({...newMod, startTime: e.target.value})} />
                </div>
                <div>
                  <label className="text-[9px] font-black text-blue-800 uppercase tracking-widest block mb-1">Termina</label>
                  <input type="time" className="w-full p-3 rounded-xl text-xs font-bold border border-blue-200 outline-none" value={newMod.endTime} onChange={e => setNewMod({...newMod, endTime: e.target.value})} />
                </div>
                <div>
                  <label className="text-[9px] font-black text-blue-800 uppercase tracking-widest block mb-1">Hora Extra</label>
                  <div className="relative">
                    <span className="absolute left-2 top-1/2 -translate-y-1/2 text-[9px] font-black text-slate-400">Bs.</span>
                    <input type="number" step="0.5" className="w-full p-3 pl-7 rounded-xl text-xs font-bold border border-blue-200 outline-none text-blue-600" value={newMod.overagePrice} onChange={e => setNewMod({...newMod, overagePrice: parseFloat(e.target.value)})} />
                  </div>
                </div>
              </div>
            )}
          </div>
          <button onClick={() => {if(newMod.name) { saveModality(newMod); setNewMod({ name: '', price: 10, type: 'hour', vehicle: 'car', startTime: '07:00', endTime: '13:00', overagePrice: 1 }); }}} className="w-full bg-blue-600 text-white p-4 rounded-2xl font-black uppercase text-xs tracking-widest active:scale-95 transition-all">Guardar Regla</button>
        </div>

        <div className="space-y-3">
          <h3 className="font-black text-slate-400 text-[10px] uppercase tracking-widest ml-2">Reglas de Cobro Activas</h3>
          {modalities.map(m => (
            <div key={m.id} className="bg-white p-4 rounded-2xl border border-slate-100 flex items-center justify-between">
              <div className="flex items-center gap-4">
                <div className="bg-blue-50 p-2.5 rounded-xl text-blue-600">
                  {m.type === 'hour' ? <Timer size={20} /> : m.type === 'block' ? <Calendar size={20} /> : <CreditCard size={20} />}
                </div>
                <div>
                  <p className="font-black text-slate-800 text-sm leading-none mb-1">{m.name}</p>
                  <div className="flex flex-col gap-0.5">
                    <p className="text-[10px] text-slate-500 font-bold uppercase">{m.vehicle === 'car' ? 'Auto' : m.vehicle === 'moto' ? 'Moto' : 'Carga'} • Bs. {m.price} {m.type === 'hour' ? '/ hora' : m.type === 'fixed' ? 'fijo' : 'base'}</p>
                    {m.type === 'block' && (
                      <p className="text-[9px] text-blue-500 font-black uppercase tracking-tighter">
                        {m.startTime} a {m.endTime} • +Bs. {m.overagePrice}/hr extra
                      </p>
                    )}
                  </div>
                </div>
              </div>
              <button onClick={() => deleteModality(m.id)} className="p-3 text-slate-300 hover:text-red-500 hover:bg-red-50 rounded-xl active:scale-90 transition-all"><Trash2 size={16} /></button>
            </div>
          ))}
        </div>
      </div>
    );
  };

  // --- RENDER PRINCIPAL ---
  if (isLocked) {
    return (
      <div className="min-h-screen bg-slate-900 flex flex-col items-center justify-center p-8 animate-in fade-in duration-500">
        <div className="w-full max-w-sm space-y-12 text-center">
          <div className="space-y-4">
            <div className="bg-blue-600 w-24 h-24 rounded-[2.5rem] flex items-center justify-center mx-auto shadow-[0_0_40px_rgba(37,99,235,0.3)]"><Lock className="text-white" size={40} /></div>
            <h1 className="text-white text-3xl font-black tracking-tight">ParkMaster <span className="text-blue-500">Pro</span></h1>
            <p className="text-slate-400 text-sm italic">Gestión de Parqueo • Bolivia</p>
          </div>
          <div className="space-y-6">
            <button onClick={handleBiometricAuth} disabled={authLoading} className="w-full bg-slate-800 border border-slate-700 p-8 rounded-[2.5rem] flex flex-col items-center gap-4 active:scale-95 transition-all group">
              <Fingerprint size={48} className={authLoading ? "text-blue-500 animate-pulse" : "text-blue-500 group-hover:scale-110 transition-transform"} />
              <span className="text-white font-bold text-sm tracking-widest uppercase">{authLoading ? 'Verificando...' : 'Acceso Biométrico'}</span>
            </button>
            <div className="relative py-4">
              <div className="absolute inset-0 flex items-center"><div className="w-full border-t border-slate-800"></div></div>
              <div className="relative flex justify-center text-xs uppercase"><span className="bg-slate-900 px-4 text-slate-500 font-bold tracking-widest">O Seleccionar Turno</span></div>
            </div>
            <div className="grid grid-cols-2 gap-3">
              {employees.map(emp => (
                <button key={emp.id} onClick={() => handleLogin(emp)} className="bg-slate-800/50 p-4 rounded-2xl border border-slate-700 text-white flex flex-col items-center gap-2 hover:bg-slate-800 active:scale-95 transition-all">
                  <Users size={20} className="text-slate-500" />
                  <span className="text-[10px] font-black uppercase tracking-tight">{emp.name}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-slate-50 font-sans pb-24 text-slate-900 select-none">
      
      {/* Indicador de Nube */}
      {syncing && (
        <div className="fixed top-4 right-4 z-[100] bg-white/90 backdrop-blur px-3 py-1.5 rounded-full border border-blue-100 flex items-center gap-2 shadow-sm animate-pulse">
          <RefreshCw size={12} className="text-blue-600 animate-spin" /><span className="text-[10px] font-black text-blue-600 uppercase tracking-tighter">Nube</span>
        </div>
      )}

      {/* MODAL: COBRO POR ESCANEO / CHECKOUT */}
      {(checkoutVehicle || isScanningQR) && (
        <div className="fixed inset-0 bg-black/80 backdrop-blur-md z-[150] flex flex-col items-center justify-center p-6 animate-in fade-in">
          {isScanningQR ? (
            <div className="w-full max-w-sm flex flex-col items-center gap-10">
              <div className="w-72 h-72 border-4 border-white/20 rounded-[3rem] relative overflow-hidden flex items-center justify-center">
                <video ref={videoRef} autoPlay playsInline className="absolute inset-0 w-full h-full object-cover opacity-50" />
                <div className="absolute inset-x-0 h-1 bg-blue-500 shadow-[0_0_20px_rgba(59,130,246,1)] animate-[scan_2s_infinite]"></div>
              </div>
              <div className="text-center space-y-2">
                <p className="text-white font-black text-xl">Escaneando Ticket</p>
                <p className="text-white/40 text-xs px-10">Enfoque el código QR para realizar el cobro.</p>
              </div>
              <div className="grid grid-cols-2 gap-2 w-full max-w-xs">
                 {activeVehicles.slice(0, 4).map(v => (
                   <button key={v.id} onClick={() => {stopCamera(); setCheckoutVehicle(v);}} className="bg-white/10 text-white p-3 rounded-2xl text-[10px] font-black uppercase border border-white/5 active:bg-blue-600">Simular {v.plate}</button>
                 ))}
              </div>
              <button onClick={stopCamera} className="text-white/40 uppercase font-black text-[10px] tracking-widest mt-4">Cancelar</button>
            </div>
          ) : (
            <div className="bg-white w-full max-w-sm rounded-[3rem] overflow-hidden shadow-2xl animate-in zoom-in-95">
              <div className="bg-blue-600 p-6 text-white flex justify-between items-center">
                <span className="font-black text-[10px] uppercase tracking-widest">Cobro de Salida</span>
                <button onClick={() => setCheckoutVehicle(null)} className="p-2 bg-white/20 rounded-full"><X size={18} /></button>
              </div>
              <div className="p-8 space-y-6">
                <div className="text-center">
                  <p className="text-5xl font-black text-slate-800 tracking-tighter mb-1">{checkoutVehicle.plate}</p>
                  <p className="text-[10px] text-blue-500 font-bold uppercase tracking-widest">ID: {checkoutVehicle.id}</p>
                  <div className="flex justify-center items-center gap-2 mt-2 text-[10px] font-black text-slate-400">
                     <span>Ingreso: {new Date(checkoutVehicle.entryTime).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</span>
                     <ArrowRight size={10} />
                     <span className="text-blue-500">Salida: {new Date().toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</span>
                  </div>
                </div>
                <div className="space-y-2">
                  <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest text-center border-b border-slate-100 pb-2">Seleccione Tarifa a Cobrar</p>
                  <div className="space-y-2 max-h-60 overflow-y-auto pt-2 pr-1">
                    {modalities.filter(m => m.vehicle === checkoutVehicle.type).map(mod => {
                      const cost = calculateModalityCost(checkoutVehicle.entryTime, Date.now(), mod);
                      return (
                        <button key={mod.id} onClick={() => handleCheckOut(checkoutVehicle, mod, cost)} className="w-full flex justify-between items-center bg-slate-50 p-5 rounded-2xl hover:bg-blue-50 border border-transparent hover:border-blue-200 transition-all active:scale-95 group text-left">
                          <div>
                            <span className="font-black text-sm text-slate-700 group-hover:text-blue-800 block leading-none mb-1">{mod.name}</span>
                            {mod.type === 'block' && <span className="text-[9px] text-blue-500 font-black uppercase tracking-widest">Turno: {mod.startTime} a {mod.endTime}</span>}
                          </div>
                          <span className="font-black text-xl text-blue-600">Bs. {cost}</span>
                        </button>
                      );
                    })}
                    {modalities.filter(m => m.vehicle === checkoutVehicle.type).length === 0 && (
                      <p className="text-center text-xs text-red-500 font-bold p-4">No hay tarifas configuradas para este vehículo.</p>
                    )}
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      )}

      {/* MODAL: TICKET DE INGRESO */}
      {showTicket && (
        <div className="fixed inset-0 bg-black/70 backdrop-blur-sm z-[100] flex items-center justify-center p-6">
          <div className="bg-white w-full max-w-sm rounded-[3rem] overflow-hidden shadow-2xl animate-in zoom-in-95">
            <div className="bg-blue-600 p-6 text-white flex justify-between items-center">
              <span className="font-black text-[10px] uppercase tracking-widest">Ticket de Ingreso</span>
              <button onClick={() => setShowTicket(null)} className="p-2 bg-white/20 rounded-full"><X size={18} /></button>
            </div>
            <div className="p-10 text-center space-y-6">
              <img src={`https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${showTicket.id}`} className="mx-auto w-40 h-40 mix-blend-multiply border-4 border-slate-50 rounded-2xl" alt="QR" />
              <p className="text-5xl font-black text-slate-800 tracking-tighter">{showTicket.plate}</p>
              <div className="grid grid-cols-2 gap-4 border-y border-slate-100 py-6 text-left">
                <div><p className="text-[9px] font-black text-slate-400 uppercase tracking-widest">Hora</p><p className="text-lg font-black text-slate-800 leading-none">{new Date(showTicket.entryTime).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</p></div>
                <div><p className="text-[9px] font-black text-slate-400 uppercase tracking-widest">ID</p><p className="text-lg font-black text-blue-600 leading-none">{showTicket.id}</p></div>
              </div>
              <p className="text-[9px] text-slate-400 font-bold uppercase tracking-widest">Operador: {showTicket.registeredBy}</p>
              <button onClick={() => window.print()} className="w-full bg-slate-900 text-white py-4 rounded-2xl font-black uppercase tracking-widest shadow-xl flex items-center justify-center gap-2 active:scale-95 transition-all"><Printer size={18} /> Imprimir</button>
            </div>
          </div>
        </div>
      )}

      {/* CONFIRMAR BAÑO */}
      {showBathConfirm && (
        <div className="fixed inset-0 bg-black/70 z-[200] flex items-center justify-center p-6 backdrop-blur-sm animate-in fade-in">
          <div className="bg-white w-full max-w-sm rounded-[2.5rem] overflow-hidden shadow-2xl">
            <div className="bg-cyan-500 p-8 text-white text-center"><Droplets size={48} className="mx-auto mb-4" /><h2 className="text-2xl font-black">Cobro de Baño</h2></div>
            <div className="p-8 space-y-4">
              <div className="bg-slate-50 p-6 rounded-2xl text-center"><p className="text-slate-400 text-[10px] font-black uppercase mb-1">Monto a Cobrar</p><p className="text-4xl font-black text-cyan-600">Bs. {bathPrice.toFixed(2)}</p></div>
              <div className="flex gap-3">
                <button onClick={() => setShowBathConfirm(false)} className="flex-1 py-4 font-black text-slate-400 uppercase text-xs">Cancelar</button>
                <button onClick={confirmBathService} className="flex-1 py-4 bg-cyan-500 text-white rounded-2xl font-black uppercase text-xs shadow-lg shadow-cyan-100 active:scale-95 transition-all">Confirmar</button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* HEADER */}
      <header className="bg-white border-b border-slate-100 p-5 sticky top-0 z-40">
        <div className="flex justify-between items-center max-w-lg mx-auto">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 bg-blue-600 rounded-xl flex items-center justify-center text-white font-black shadow-lg shadow-blue-500/20">{user?.displayName?.charAt(0) || 'P'}</div>
            <div>
              <p className="text-xs font-black text-slate-800 leading-none">{user?.displayName || 'Operador'}</p>
              <p className="text-[10px] text-slate-400 font-bold uppercase tracking-widest">{user?.role || 'Staff'}</p>
            </div>
          </div>
          <div className="flex items-center gap-2">
            <button onClick={() => startCamera(false)} className="bg-blue-600 text-white p-3 rounded-2xl shadow-lg shadow-blue-100 active:scale-90 transition-all flex items-center gap-2">
              <QrCode size={20} /><span className="text-[10px] font-black uppercase pr-1">Cobrar</span>
            </button>
            <button onClick={() => setIsLocked(true)} className="p-3 bg-slate-100 text-slate-400 rounded-xl active:bg-slate-200"><Lock size={18} /></button>
          </div>
        </div>
      </header>

      <main className="max-w-lg mx-auto p-4 space-y-4">
        
        {/* DASHBOARD */}
        {view === 'dashboard' && (
          <>
            <div className="flex gap-2">
              <div className="flex-1 bg-white border border-slate-100 p-4 rounded-[2rem] flex items-center justify-between">
                <div>
                  <p className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Ocupación</p>
                  <p className="text-xl font-black text-slate-800"><span className="text-blue-600">{activeVehicles.length}</span> / {capacity}</p>
                </div>
                <div className={`w-3 h-3 rounded-full ${activeVehicles.length >= capacity ? 'bg-red-500 animate-pulse' : 'bg-emerald-500'}`}></div>
              </div>
              <button onClick={() => setShowBathConfirm(true)} className="flex-1 bg-cyan-500 text-white p-4 rounded-[2rem] shadow-lg shadow-cyan-100 flex flex-col items-center justify-center active:scale-95 transition-all">
                <Droplets size={24} className="mb-1" />
                <span className="font-black text-xs uppercase tracking-widest">Baño</span>
              </button>
            </div>

            <div className="relative">
              <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" size={18} />
              <input type="text" placeholder="Buscar placa o ID..." className="w-full pl-12 pr-4 py-4 bg-white border border-slate-200 rounded-3xl outline-none focus:border-blue-500 shadow-sm font-medium uppercase" value={searchQuery} onChange={(e) => setSearchQuery(e.target.value)} />
            </div>

            <div className="space-y-3">
              {filteredVehicles.map((v) => (
                <div key={v.id} className="bg-white p-5 rounded-[2rem] shadow-sm border border-slate-100">
                  <div className="flex justify-between items-start mb-5">
                    <div className="flex items-center gap-4">
                      <div className="bg-slate-50 p-3 rounded-2xl text-slate-600">{v.type === 'moto' ? <Bike size={22} /> : v.type === 'truck' ? <Truck size={22} /> : <Car size={22} />}</div>
                      <div>
                        <p className="text-xl font-black text-slate-800 tracking-tighter leading-none mb-1">{v.plate}</p>
                        <p className="text-[9px] text-slate-400 font-bold uppercase">Entrada: {new Date(v.entryTime).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'})}</p>
                      </div>
                    </div>
                    <div className="text-right">
                      <p className="text-[10px] text-slate-400 font-black uppercase mb-1">Sug. Base</p>
                      <p className="text-xl font-black text-blue-600">Bs. {getSuggestedCost(v)}</p>
                    </div>
                  </div>
                  <button onClick={() => setCheckoutVehicle(v)} className="w-full bg-slate-50 text-slate-600 py-3.5 rounded-2xl text-[10px] font-black uppercase tracking-widest border border-slate-100 active:bg-blue-600 active:text-white transition-all">Cobrar y Dar Salida</button>
                </div>
              ))}
              {filteredVehicles.length === 0 && (
                <div className="text-center py-20 bg-white rounded-[3rem] border border-dashed border-slate-200">
                   <p className="text-slate-300 text-[10px] font-black uppercase tracking-widest">Estacionamiento Vacío</p>
                </div>
              )}
            </div>
          </>
        )}

        {/* ENTRADA (CON CÁMARA OCR) */}
        {view === 'entry' && (
          <div className="bg-white rounded-[2.5rem] p-8 shadow-sm border border-slate-100 animate-in slide-in-from-bottom-8">
            <h2 className="text-2xl font-black mb-8 flex items-center gap-3"><div className="bg-blue-100 p-2 rounded-xl text-blue-600"><Plus size={24} /></div> Ingreso</h2>
            <form onSubmit={handleCheckIn} className="space-y-8">
              <div>
                <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3 block ml-1">Matrícula</label>
                <div className="relative">
                  <input type="text" required placeholder="AAA-000" className="w-full p-5 bg-slate-50 border border-slate-200 rounded-[1.5rem] focus:border-blue-500 outline-none uppercase text-3xl font-black text-center tracking-widest" value={formData.plate} onChange={(e) => setFormData({...formData, plate: e.target.value})} />
                  <button type="button" onClick={() => startCamera(true)} className="absolute right-3 top-1/2 -translate-y-1/2 bg-white p-3 rounded-2xl shadow-sm border border-slate-100 text-blue-600 active:scale-90 transition-all"><Camera size={24} /></button>
                </div>
              </div>
              <div>
                <label className="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4 block ml-1">Tipo</label>
                <div className="grid grid-cols-3 gap-3">
                  {['car', 'moto', 'truck'].map(t => (
                    <button key={t} type="button" onClick={() => setFormData({...formData, type: t})} className={`p-5 rounded-[1.5rem] border-2 flex flex-col items-center gap-3 transition-all ${formData.type === t ? 'bg-blue-600 border-blue-600 text-white shadow-xl shadow-blue-200' : 'bg-white border-slate-50 text-slate-300'}`}>
                      {t === 'car' ? <Car size={28} /> : t === 'moto' ? <Bike size={28} /> : <Truck size={28} />}
                      <span className="text-[10px] font-black uppercase">{t === 'car' ? 'Auto' : t === 'moto' ? 'Moto' : 'Carga'}</span>
                    </button>
                  ))}
                </div>
              </div>
              <button type="submit" disabled={activeVehicles.length >= capacity} className="w-full bg-blue-600 text-white p-6 rounded-[1.5rem] font-black text-lg shadow-2xl shadow-blue-100 uppercase tracking-widest active:scale-95 transition-all disabled:bg-slate-300">Generar Ticket</button>
            </form>
          </div>
        )}

        {/* CAJA / HISTORIAL */}
        {view === 'history' && (
          <div className="space-y-4 animate-in fade-in">
            <div className="bg-slate-900 p-8 rounded-[2.5rem] text-white shadow-2xl relative overflow-hidden">
              <p className="text-white/40 text-[10px] uppercase font-black tracking-widest mb-2">Recaudación Diaria</p>
              <p className="text-5xl font-black tracking-tighter">Bs. {stats.day.total.toFixed(2)}</p>
              <div className="mt-8 relative z-10 flex gap-2">
                <button onClick={() => exportToCSV('hoy', historyRecords.filter(h => new Date(h.exitTime).setHours(0,0,0,0) === new Date().setHours(0,0,0,0)))} className="bg-blue-600 p-3.5 rounded-2xl active:scale-90 transition-all flex items-center gap-2 text-[10px] font-black uppercase tracking-widest"><Download size={16} /> Hoy</button>
                <button onClick={() => exportToCSV('historico', historyRecords)} className="bg-slate-800 p-3.5 rounded-2xl active:scale-90 transition-all flex items-center gap-2 text-[10px] font-black uppercase tracking-widest">Todo</button>
              </div>
              <BarChart3 size={120} className="absolute -right-8 -bottom-8 text-white/5 rotate-12" />
            </div>
            <div className="bg-white rounded-[2.5rem] p-6 shadow-sm border border-slate-100">
              <h3 className="font-black text-slate-800 text-sm mb-6 px-2 flex justify-between">Transacciones <span className="text-[9px] text-slate-400 font-bold uppercase">(Ingreso → Salida)</span></h3>
              <div className="space-y-4">
                {historyRecords.slice(0, 15).map((record) => (
                  <div key={record.id} className="flex justify-between items-center group border-b border-slate-50 pb-4 last:border-0">
                    <div className="flex items-center gap-4">
                      <div className={`p-2.5 rounded-xl ${record.type === 'baño' ? 'bg-cyan-50 text-cyan-500' : 'bg-slate-50 text-slate-400'}`}>
                        {record.type === 'baño' ? <Droplets size={16} /> : <Car size={16} />}
                      </div>
                      <div>
                        <div className="flex items-center gap-2 mb-1">
                          <p className="font-black text-slate-700 text-sm leading-none">{record.plate}</p>
                          {record.type !== 'baño' && <span className="text-[8px] font-black bg-slate-100 text-slate-400 px-1.5 py-0.5 rounded">{record.rateApplied}</span>}
                        </div>
                        <p className="text-[9px] text-slate-400 font-bold uppercase">
                          {new Date(record.entryTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })} → {new Date(record.exitTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })} • Op: {record.processedBy}
                        </p>
                      </div>
                    </div>
                    <p className={`font-black text-sm tracking-tighter ${record.type === 'baño' ? 'text-cyan-600' : 'text-emerald-600'}`}>+Bs. {record.totalCost}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        {/* AJUSTES / MODALIDADES */}
        {view === 'settings' && (
          <div className="space-y-6 animate-in slide-in-from-bottom-8">
             <div className="bg-white rounded-[2.5rem] p-8 shadow-sm border border-slate-100">
               <div className="flex justify-between items-end mb-4"><span className="text-[10px] font-black text-slate-400 uppercase tracking-widest">Espacios Totales</span><span className="text-3xl font-black text-blue-600">{capacity}</span></div>
               <input type="range" min="1" max="200" className="w-full h-2 bg-slate-100 rounded-lg appearance-none accent-blue-600 cursor-pointer" value={capacity} onChange={(e) => setCapacity(Number(e.target.value))} />
            </div>

            <div className="space-y-4">
              <h2 className="text-lg font-black text-slate-800 ml-2">Gestión de Tarifas</h2>
              <ModalityEditor />
            </div>

            <div className="bg-cyan-500 p-8 rounded-[2.5rem] text-white shadow-xl shadow-cyan-100 flex justify-between items-center">
                <div>
                  <h2 className="text-sm font-black mb-1 flex items-center gap-2"><Droplets size={16} /> Precio Baño</h2>
                  <p className="text-[10px] text-cyan-200 uppercase tracking-widest">Por uso</p>
                </div>
                <div className="relative"><span className="absolute left-3 top-1/2 -translate-y-1/2 text-sm font-black text-cyan-200">Bs.</span><input type="number" step="0.5" className="w-24 p-4 pl-8 bg-white/10 border border-white/20 rounded-2xl text-lg font-black text-center outline-none focus:ring-2 ring-white/50" value={bathPrice} onChange={(e) => setBathPrice(parseFloat(e.target.value))} /></div>
            </div>

            {user?.role === 'admin' && (
               <button onClick={() => { if(window.confirm('¿Formatear toda la base de datos de ingresos y vehículos?')) { setHistoryRecords([]); setActiveVehicles([]); } }} className="w-full bg-red-50 text-red-600 p-6 rounded-[1.5rem] font-black text-xs uppercase tracking-widest active:scale-95 transition-all">Formatear Sistema</button>
            )}
          </div>
        )}
      </main>

      {/* OCR CAMERA OVERLAY */}
      {isScanningPlate && (
        <div className="fixed inset-0 bg-black z-[200] flex flex-col animate-in fade-in">
          <div className="flex-1 relative flex items-center justify-center">
            <video ref={videoRef} autoPlay playsInline className="absolute inset-0 w-full h-full object-cover opacity-60" />
            <div className="w-80 h-32 border-2 border-white/50 rounded-3xl relative">
              <div className="absolute inset-x-0 h-1 bg-blue-500 shadow-[0_0_20px_rgba(59,130,246,1)] animate-[scan_2s_infinite]"></div>
              {ocrLoading && <div className="absolute inset-0 flex items-center justify-center bg-blue-600/80 rounded-[1.4rem]"><RotateCcw size={32} className="text-white animate-spin" /></div>}
            </div>
          </div>
          <div className="bg-slate-900 p-10 flex flex-col items-center gap-6">
            <p className="text-white/50 text-[10px] font-black uppercase tracking-widest">Alinee la placa en el recuadro</p>
            <div className="flex items-center gap-8">
              <button onClick={stopCamera} className="text-white/40 p-2"><X size={32} /></button>
              <button onClick={simulateOCR} disabled={ocrLoading} className="w-20 h-20 bg-white rounded-full flex items-center justify-center shadow-2xl active:scale-90 transition-all"><ScanText size={32} className="text-slate-900" /></button>
              <div className="w-10"></div>
            </div>
          </div>
        </div>
      )}

      {/* BOTTOM NAV */}
      <nav className="fixed bottom-0 left-0 right-0 bg-white border-t border-slate-100 flex justify-around p-3 pb-8 shadow-[0_-10px_30px_rgba(0,0,0,0.03)] z-50">
        {[
          { id: 'dashboard', icon: LayoutDashboard, label: 'Activos' },
          { id: 'entry', icon: Plus, label: 'Entrada' },
          { id: 'history', icon: BarChart3, label: 'Caja' },
          { id: 'settings', icon: Settings, label: 'Ajustes' }
        ].map(item => (
          <button key={item.id} onClick={() => setView(item.id)} className={`flex flex-col items-center gap-1 transition-all duration-300 relative ${view === item.id ? 'text-blue-600 scale-110' : 'text-slate-300'}`}>
            <item.icon size={22} strokeWidth={view === item.id ? 2.5 : 2} />
            <span className="text-[9px] font-black uppercase tracking-tighter">{item.label}</span>
          </button>
        ))}
      </nav>
      
      <style>{`@keyframes scan { 0%, 100% { top: 0% } 50% { top: 100% } }`}</style>
    </div>
  );
};

export default App;
